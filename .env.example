# ============================================
# محیط فعلی (development / production)
# ============================================
NODE_ENV=development

# ============================================
# تنظیمات سرور
# ============================================
PORT=3001
HOSTNAME=localhost

# ============================================
# آدرس فرانت‌اند (برای CORS)
# ============================================
FRONTEND_URL=http://localhost:5173

# ============================================
# آدرس WebSocket عمومی (برای کلاینت)
# ============================================
WS_URL=ws://localhost:3001

# ============================================
# تنظیمات لاگ
# ============================================
LOG_LEVEL=debug